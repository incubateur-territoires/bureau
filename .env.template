# =============================================================================
# ProConnect Configuration
# =============================================================================
# URL de l'issuer ProConnect (environnement d'intégration ou production)
PROCONNECT_ISSUER=https://proconnect.integraci.gouv.fr

# Identifiants de l'applicationregistrée sur ProConnect
PROCONNECT_CLIENT_ID=your_client_id_here
PROCONNECT_CLIENT_SECRET=your_client_secret_here

# =============================================================================
# NextAuth Configuration
# =============================================================================
# URL de l'application (pour les callbacks OIDC)
NEXTAUTH_URL=http://localhost:3000

# Secret pour le chiffrement des sessions (générer avec: openssl rand -hex 32)
NEXTAUTH_SECRET=your_random_secret_here_generate_with_openssl_rand_hex_32

# =============================================================================
# Application Settings
# =============================================================================
# Désactiver l'authentification en développement (optionnel)
AUTH_ENABLED=true

# Email de bypass pour le développement (si AUTH_ENABLED=false)
AUTH_DEV_BYPASS_EMAIL=dev@example.com
